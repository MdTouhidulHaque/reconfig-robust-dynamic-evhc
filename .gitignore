.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# Large raw and intermediate data
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/sample/*
!data/sample/.gitkeep

# Trained models and generated results
models/*
!models/.gitkeep
results/*
!results/.gitkeep

# Logs and temporary outputs
*.log
*.tmp
*.bak

# Local config override
configs/paths.yaml

# Optional archival files
*.zip
*.7z
*.tar
*.gz
